# --- Required (rubric names + app aliases) ---
PORT=3000
BACKEND_PORT=3000
FRONTEND_PORT=8080
NODE_ENV=development
ENVIRONMENT=development

DATABASE_URL=postgresql://postgres:1234@localhost:5432/leanstock
REDIS_URL=redis://localhost:6379

# JWT (rubric: JWT_SECRET_KEY / JWT_REFRESH_SECRET_KEY — mapped in docker-compose)
JWT_ACCESS_SECRET=change_me_min_16_chars_access
JWT_REFRESH_SECRET=change_me_min_16_chars_refresh
JWT_SECRET_KEY=change_me_min_16_chars_access
JWT_REFRESH_SECRET_KEY=change_me_min_16_chars_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

QUEUE_PREFIX=leanstock
POSTGRES_PASSWORD=1234

# Public URL for email links (verification, password reset)
APP_PUBLIC_URL=http://localhost:8080

# CORS (rubric: CORS_ORIGINS)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ORIGINS=http://localhost:8080,http://localhost:3000

# --- Email (SendGrid/Mailgun via SMTP or API key as SMTP password) ---
EMAIL_API_KEY=
EMAIL_FROM_ADDRESS=LeanStock <noreply@example.com>
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=LeanStock <noreply@example.com>

# true — skip SMTP calls (local debug only)
DISABLE_EMAIL_SEND=true

# true — auto-verify on register (dev only)
SKIP_EMAIL_VERIFICATION=true

# ENABLE_TEST_QUEUES=true — run BullMQ in Jest integration tests
