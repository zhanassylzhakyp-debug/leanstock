# --- Обязательные ---
PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://postgres:1234@localhost:5432/leanstock

JWT_ACCESS_SECRET=change_me_min_16_chars_access
JWT_REFRESH_SECRET=change_me_min_16_chars_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

REDIS_URL=redis://localhost:6379
QUEUE_PREFIX=leanstock

# Публичный URL API (ссылки в письмах: верификация, сброс пароля)
APP_PUBLIC_URL=http://localhost:3000

# CORS: через запятую, без * в production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- SMTP (обязательны в dev/prod, если не отключена отправка) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=LeanStock <noreply@example.com>

# true — не вызывать SMTP (локальная отладка без почты)
DISABLE_EMAIL_SEND=false

# true — сразу помечать email подтверждённым при регистрации (только dev)
SKIP_EMAIL_VERIFICATION=false

# В тестах Jest NODE_ENV=test — SMTP не требуется
# ENABLE_TEST_QUEUES=true — включить реальные очереди BullMQ в тестах (по умолчанию выкл.)
